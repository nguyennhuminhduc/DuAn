<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arsenal 3–0 AS Monaco</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#f5f5f5;color:#222;min-height:100vh;font-size:13px}

/* ── TOP SCORE BAR ── */
.top-bar{background:#fff;border-bottom:1px solid #e0e0e0;padding:8px 16px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.comp-label{font-size:11px;color:#888}
.score-block{display:flex;align-items:center;gap:14px;flex:1;justify-content:center}
.team-s{display:flex;align-items:center;gap:7px;font-weight:600;font-size:14px;color:#222}
.crest{font-size:20px}
.score-nums{font-weight:700;font-size:24px;color:#222;letter-spacing:1px}
.ft-tag{font-size:11px;font-weight:600;color:#4caf50;border:1px solid #4caf50;padding:1px 6px;border-radius:3px}

/* ── MAIN LAYOUT ── */
.layout{display:flex;gap:12px;max-width:1160px;margin:0 auto;padding:14px 12px 40px}

/* ── LEFT PANEL ── */
.left-panel{width:296px;flex-shrink:0;display:flex;flex-direction:column;gap:8px}
.card{background:#fff;border:1px solid #e0e0e0;border-radius:8px;overflow:hidden}
.card-title{font-size:11px;font-weight:600;color:#555;text-transform:uppercase;letter-spacing:.4px;padding:9px 12px 7px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:6px}

/* Handicap */
.hc-header{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-bottom:1px solid #f0f0f0;font-size:12px;font-weight:600;color:#222}
.bet-logo{background:#1a56db;color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:3px;letter-spacing:.5px}
.handicap-row{display:flex}
.hc-side{flex:1;padding:10px 12px;text-align:center;cursor:pointer;transition:background .15s}
.hc-side:hover{background:#f9f9f9}
.hc-side:first-child{border-right:1px solid #f0f0f0}
.hc-label{font-size:11px;color:#666;margin-bottom:4px}
.hc-odds{font-size:22px;font-weight:700;color:#222}
.hc-trend{font-size:10px;margin-top:2px}
.trend-up{color:#4caf50}
.trend-dn{color:#ef5350}
.hc-footer{padding:4px 12px 6px;font-size:10px;color:#aaa;display:flex;justify-content:space-between;align-items:center}
.add-odds{font-size:11px;color:#1a56db;cursor:pointer}

/* Momentum chart */
.momentum-wrap{padding:10px 12px 8px}
.momentum-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}
.momentum-label{font-size:11px;font-weight:600;color:#444}
.momentum-link{font-size:11px;color:#1a56db;cursor:pointer}
.chart-canvas{width:100%;height:64px;display:flex;align-items:center;gap:0}
.chart-col{flex:1;display:flex;flex-direction:column;height:64px}
.bar-a{background:#ef0107;border-radius:1px 1px 0 0;margin:0 .5px}
.bar-gap{height:1px;background:#e0e0e0}
.bar-m{background:#c0392b;opacity:.5;border-radius:0 0 1px 1px;margin:0 .5px}
.chart-labels{display:flex;justify-content:space-between;font-size:10px;color:#888;margin-top:4px}

/* POTM */
.potm-inner{display:flex;align-items:center;gap:10px;padding:10px 12px}
.potm-avatar{width:42px;height:42px;border-radius:50%;background:#e8eaf6;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.potm-info{flex:1}
.potm-name{font-weight:700;font-size:14px;color:#111}
.potm-club{font-size:11px;color:#888;margin-top:1px;display:flex;align-items:center;gap:4px}
.potm-club .dot{width:7px;height:7px;border-radius:50%;background:#ef0107;display:inline-block;flex-shrink:0}
.potm-rating{font-weight:800;font-size:17px;color:#fff;background:#4caf50;padding:4px 10px;border-radius:5px;min-width:42px;text-align:center}

/* Timeline */
.tl-wrap{padding:4px 12px 10px}
.tl-item{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #f5f5f5}
.tl-item:last-of-type{border-bottom:none}
.tl-min{font-size:11px;color:#888;width:28px;flex-shrink:0;padding-top:1px}
.tl-icon{font-size:14px;flex-shrink:0}
.tl-body{flex:1}
.tl-score{font-weight:700;color:#111;font-size:13px}
.tl-who{font-size:11px;color:#666;margin-top:1px}
.tl-who strong{color:#222;font-weight:600}
.sub-item{display:flex;align-items:center;gap:8px;padding:4px 0;font-size:11px;color:#888;border-bottom:1px solid #f5f5f5}
.sub-item:last-child{border-bottom:none}
.sub-time{width:28px;flex-shrink:0;color:#aaa}
.sub-icon{color:#f59e0b}

/* ── RIGHT PANEL ── */
.right-panel{flex:1;min-width:0}

/* Main tabs */
.main-tabs{display:flex;border-bottom:2px solid #e0e0e0;margin-bottom:10px;background:#fff;border-radius:8px 8px 0 0;overflow:hidden}
.main-tab{padding:11px 22px;font-size:13px;font-weight:600;color:#888;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;letter-spacing:.3px}
.main-tab.active{color:#1a56db;border-bottom-color:#1a56db}
.main-tab:hover:not(.active){color:#444}

/* Sub-stat tabs */
.sub-tabs{display:flex;gap:4px;margin-bottom:10px;flex-wrap:wrap}
.sub-tab{padding:5px 14px;font-size:12px;font-weight:500;border-radius:20px;border:1px solid #e0e0e0;background:#fff;color:#555;cursor:pointer;transition:all .15s}
.sub-tab.active{background:#222;color:#fff;border-color:#222}
.sub-tab:hover:not(.active){border-color:#aaa;color:#222}

/* Table */
.tbl-wrap{background:#fff;border:1px solid #e0e0e0;border-radius:8px;overflow:auto}
table{width:100%;border-collapse:collapse;min-width:700px}
thead tr{background:#fafafa;border-bottom:1px solid #ebebeb}
th{padding:9px 7px;font-size:10px;font-weight:600;color:#888;text-align:center;white-space:nowrap;vertical-align:bottom;line-height:1.3}
th:first-child{text-align:left;padding-left:12px}
td{padding:9px 7px;text-align:center;border-bottom:1px solid #f5f5f5;color:#555}
td:first-child{text-align:left;padding-left:12px}
tbody tr:last-child td{border-bottom:none}
tbody tr:hover{background:#fafbff}
.pcell{display:flex;align-items:center;gap:8px}
.pdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.pname{font-weight:600;color:#111;font-size:13px}
.chip{display:inline-block;font-weight:700;font-size:12px;border-radius:4px;padding:3px 7px;color:#fff;min-width:34px;text-align:center}
.c-great{background:#2e7d32}
.c-good{background:#388e3c}
.c-ok{background:#f59e0b}
.c-avg{background:#ef6c00}
td.val{color:#111;font-weight:600}
td.zero{color:#ccc}
.pos-chip{font-size:10px;background:#f0f0f0;color:#666;font-weight:600;padding:2px 6px;border-radius:3px}
th.sortable{cursor:pointer;user-select:none}
th.sortable:hover{color:#444}
th.sort-active{color:#1a56db}
.sort-arrow{margin-left:2px;font-size:9px}
.th-crests{display:flex;align-items:center;gap:3px;font-size:15px}

/* Tab panes */
.tab-pane{display:none}
.tab-pane.active{display:block}
</style>
</head>
<body>

